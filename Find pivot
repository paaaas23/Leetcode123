class Solution {
    public int pivotIndex(int[] nums) {
        int n=nums.length;
        int lsum=0;
        for(int i=0;i<n;i++){
            
            int sum=0;
            int a=i+1;
            while(a<n){
                sum+=nums[a];
                a++;
            }
            if(sum==lsum){
                return i;
            }
            lsum+=nums[i];
            
        }
        return -1;
    }
}
